# 复制为 /root/cf-dns-speedup/config.env 后填写。

# 推送模式：domain=更新 Cloudflare DNS；ip=只输出优选 IP，不更新 DNS。
PUSH_MODE="domain"

# 域名更新方案：
# multi=多个优选 IP 解析到一个域名；
# one_to_one=每个优选 IP 解析到每个域名。
DOMAIN_UPDATE_MODE="multi"

# CDN IP 来源：official=Cloudflare 官方 IP；reverse=反代 IP 库。
CDN_IP_MODE="official"

# Cloudflare API Token，建议只给 Zone:Read + DNS:Edit，且只限制到目标 Zone。
CF_API_TOKEN="put_your_cloudflare_api_token_here"
CF_ZONE_ID="put_your_zone_id_here"

# multi 模式使用这个完整域名，例如 best.example.com。
CF_RECORD_NAME="best.example.com"

# one_to_one 模式使用这些完整域名，空格分隔。
CF_RECORD_NAMES="a.example.com b.example.com"

CF_PROXIED=false
CF_TTL=60

# CloudflareSpeedTest 参数。
CFST_PORT=443
CFST_THREADS=32
CFST_COUNT=5
CFST_DOWNLOAD_COUNT=100
CFST_DOWNLOAD_COUNT_STEP=0
CFST_DOWNLOAD_COUNT_MAX=100
CFST_RESULT_COUNT=5
CFST_TIMEOUT=4
CFST_TOTAL_TIMEOUT=3600
CFST_DOWNLOAD_TIMEOUT=25
CFST_MIN_SPEED=0
CFST_PREFER_MIN_SPEED=10
CFST_STABILITY_TEST_COUNT=12
CFST_STABILITY_TEST_ROUNDS=2
CFST_STABILITY_CONNECT_TIMEOUT=6
CFST_STABILITY_TIMEOUT=35
VALIDATE_CURRENT_ROUNDS=2
CFST_OBSERVE_CRON="30 14,20 * * *"
CFST_OBSERVE_MIN_SPEED=8
CFST_PRIMARY_SAFE_MODE=1
CFST_PRIMARY_MIN_SPEED=8
CFST_PRIMARY_PREFER_REGEX='^104\.17\.'
CFST_PRIMARY_AVOID_REGEX='^(104\.20\.|104\.26\.|172\.67\.)'
CFST_PRIMARY_ALLOW_CHALLENGER=0
CFST_PRIMARY_QUORUM_MODE=1
CFST_PRIMARY_QUORUM_MIN_OBSERVATIONS=2
CFST_PRIMARY_QUORUM_RECENT_PASSES=2
CFST_PRIMARY_DEGRADE_PROTECTION=1
CFST_PRIMARY_DEGRADE_MIN_SPEED=2
CFST_PRIMARY_GUARD_ENFORCE=1
CFST_STABLE_SLOT_ALLOW_CHALLENGER=0
CFST_STABLE_SLOT_ALLOW_AVOID=0
CFST_COMPARE_CURRENT_DNS=1
CFST_CHAMPION_POOL=1
CFST_CHAMPION_POOL_SIZE=10
CFST_RETAIN_RATIO=0.90
CFST_REPLACE_IMPROVE_RATIO=1.25
CFST_DEGRADE_MIN_SPEED=2
CFST_RETAIN_MIN_SPEED=8
CFST_CHAMPION_FAIL_MIN_SPEED=8
CFST_FAIL_EVICT_COUNT=3
CFST_FINAL_CANDIDATE_LIMIT=30
CFST_EXTERNAL_CANDIDATES=0
CFST_EXTERNAL_CANDIDATE_URLS=""
CFST_EXTERNAL_CANDIDATE_ALLOWED_HOSTS="raw.githubusercontent.com"
CFST_EXTERNAL_CANDIDATE_LIMIT=5000
CFST_EXTERNAL_CANDIDATE_SOURCE_LIMIT=2000
CFST_EXTERNAL_CANDIDATE_URL_LIMIT=5
CFST_EXTERNAL_CANDIDATE_MAX_BYTES=1048576
CFST_EXTERNAL_CANDIDATE_MAX_LINES=20000
CFST_EXTERNAL_CANDIDATES_ALLOW_DNS=0
CFST_EXTERNAL_CANDIDATES_ALLOW_CHAMPION=0
CFST_EXTERNAL_OBSERVATION_POOL=1
CFST_EXTERNAL_PROMOTION_ROUNDS=3
CFST_EXTERNAL_PROMOTION_MIN_SPEED=8
CFST_EXTERNAL_OBSERVATION_EVICT_FAILS=3
CFST_ISP_PROFILE=""
CFST_MAX_LATENCY=220
CFST_MIN_LATENCY=0

# 留空表示只做延迟优选。示例：
# CFST_URL="https://speed.cloudflare.com/__down?bytes=104857600"
CFST_URL=""

# ipv4 或 ipv6。
IP_VERSION="ipv4"

# 代理插件：0=不控制，1=Passwall，2=Passwall2，3=SSR-Plus，4=Clash，
# 5=OpenClash，6=Bypass，7=V2raya，8=Hello-World，9=Homeproxy，
# 10=MihomoTProxy，11=ShellCrash。
PROXY_PLUGIN=0
PROXY_RESTART_WAIT=30

# 通知配置，留空表示关闭。
TELEGRAM_BOT_TOKEN=""
TELEGRAM_USER_ID=""
TELEGRAM_API="api.telegram.org"
PUSHPLUS_TOKEN=""

# 1=只测试不修改 DNS；0=真实更新/删除 DNS。
DRY_RUN=1

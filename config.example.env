# Copy to /root/cf-dns-speedup/config.env on OpenWrt and fill in your values.

# Cloudflare API token with Zone:Read and DNS:Edit permission for this zone.
CF_API_TOKEN="put_your_cloudflare_api_token_here"
CF_ZONE_ID="put_your_zone_id_here"

# Full DNS name to update, for example best.example.com.
CF_RECORD_NAME="best.example.com"
CF_RECORD_TYPE="A"
CF_PROXIED=false
CF_TTL=60

# CloudflareSpeedTest settings. Conservative defaults avoid OpenWrt hangs.
CFST_PORT=443
CFST_THREADS=32
CFST_COUNT=5
CFST_TIMEOUT=4
CFST_TOTAL_TIMEOUT=900
CFST_DOWNLOAD_TIMEOUT=8
CFST_MIN_SPEED=0
CFST_MAX_LATENCY=9999
CFST_MIN_LATENCY=0

# Empty means latency-only mode. Example download URL:
# CFST_URL="https://speed.cloudflare.com/__down?bytes=104857600"
CFST_URL=""

# ipv4 or ipv6.
IP_VERSION="ipv4"

# Set to 1 to test without changing Cloudflare DNS.
DRY_RUN=1
